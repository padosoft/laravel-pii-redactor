{
    "name": "padosoft/laravel-pii-redactor",
    "description": "Italian-first PII redaction pipeline for Laravel: deterministic regex + checksum-validated detectors (codice fiscale, P.IVA, IBAN), pluggable strategies (mask / hash / tokenise / drop), GDPR + EU AI Act ready.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": [
        "laravel",
        "pii",
        "gdpr",
        "ai-act",
        "redaction",
        "anonymization",
        "pseudonymisation",
        "tokenisation",
        "italian",
        "codice-fiscale",
        "partita-iva",
        "iban",
        "luhn",
        "compliance"
    ],
    "authors": [
        {
            "name": "Lorenzo Padovani",
            "email": "lorenzo.padovani@padosoft.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "symfony/yaml": "^7.0|^8.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "suggest": {
        "padosoft/eval-harness": "Pair the PII redactor with a deterministic eval-harness suite to detect regression on detector precision/recall over time."
    },
    "autoload": {
        "psr-4": {
            "Padosoft\\PiiRedactor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Padosoft\\PiiRedactor\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padosoft\\PiiRedactor\\PiiRedactorServiceProvider"
            ],
            "aliases": {
                "Pii": "Padosoft\\PiiRedactor\\Facades\\Pii"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
