{
  "title": "laravel-pii-redactor",
  "description": "EU-first PII redaction for Laravel with deterministic detectors, opt-in country packs, and pluggable redaction strategies.",
  "url": "https://doc.laravel-pii-redactor.padosoft.com",
  "src": "docs",
  "out": "_site",
  "base": "/",
  "favicon": "/assets/favicon.svg",
  "copyCode": true,
  "pageNavigation": true,
  "minify": true,
  "theme": {
    "name": "default",
    "appearance": "system",
    "primaryColor": "#0d9488",
    "customCss": ["/assets/custom.css"]
  },
  "layout": {
    "spa": true,
    "header": { "enabled": true },
    "sidebar": {
      "enabled": true,
      "collapsible": true,
      "defaultCollapsed": false,
      "position": "left"
    },
    "breadcrumbs": true,
    "footer": {
      "style": "minimal",
      "content": "Apache-2.0 documentation for padosoft/laravel-pii-redactor.",
      "branding": false
    }
  },
  "footer": {
    "copyright": "Copyright 2026 Padosoft",
    "links": [
      { "text": "GitHub", "url": "https://github.com/padosoft/laravel-pii-redactor" },
      { "text": "Packagist", "url": "https://packagist.org/packages/padosoft/laravel-pii-redactor" }
    ]
  },
  "optionsMenu": {
    "position": "header",
    "components": {
      "search": true,
      "themeSwitch": true
    }
  },
  "plugins": {
    "search": {
      "semantic": true,
      "model": "Xenova/all-MiniLM-L6-v2",
      "include": ["**/*.md"],
      "exclude": ["**/.git/**", "**/_site/**", "**/.docmd-search/**"],
      "chunkSize": 512,
      "chunkOverlap": 64,
      "showConfidence": false,
      "showFilters": true
    },
    "git": {
      "repo": "https://github.com/padosoft/laravel-pii-redactor",
      "branch": "main",
      "editLink": true,
      "lastUpdated": true,
      "commitHistory": true,
      "maxCommits": 5,
      "dateFormat": "relative"
    },
    "seo": {
      "titleTemplate": "%s | laravel-pii-redactor",
      "description": "EU-first PII redaction for Laravel with deterministic detectors and reversible tokenisation.",
      "ogImage": "/assets/favicon.svg"
    },
    "sitemap": {
      "url": "https://doc.laravel-pii-redactor.padosoft.com"
    },
    "mermaid": {
      "theme": "default"
    },
    "math": {
      "katex": {}
    },
    "llms": {
      "enabled": true,
      "title": "laravel-pii-redactor documentation"
    },
    "analytics": {
      "enabled": false
    }
  },
  "navigation": [
    { "text": "Overview", "url": "/" },
    {
